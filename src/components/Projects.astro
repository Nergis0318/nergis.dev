---
const projects = [
    {
        title: "LRU.KR",
        description:
            "Python FastAPI와 Redis로 만든 가볍고 빠른 오픈소스 URL 단축 서비스예요.",
        tech: ["Python", "FastAPI", "Redis"],
        link: "https://github.com/Nergis0318/LRU.KR",
        repo: "https://github.com/Nergis0318/LRU.KR",
    },
    {
        title: "Office_EWP_InstallTool",
        description:
            "Windows에서 Microsoft Office Deployment Tool로 Excel, Word, PowerPoint를 편하게 설치할 수 있는 포터블 UI 도구예요.",
        tech: ["C#"],
        link: "https://github.com/Nergis0318/Office_EWP_InstallTool",
        repo: "https://github.com/Nergis0318/Office_EWP_InstallTool",
    },
    {
        title: "GeekNews-Telegram-Bot",
        description:
            "RSS로 GeekNews 기사를 모아서 텔레그램으로 보내주는 봇이에요.",
        tech: ["Python"],
        link: "https://t.me/news_hada_io_bot",
        repo: "https://github.com/Nergis0318/GeekNews-Telegram-Bot",
    },
    {
        title: "TryCloudflareGUI",
        description: "TryCloudflare를 GUI로 편하게 쓸 수 있게 해주는 도구예요.",
        tech: ["CSS"],
        repo: "https://github.com/Nergis0318/TryCloudflareGUI",
    },
    {
        title: "YU-RI",
        description:
            "리눅스 미러를 위한 고성능 프록시 서버에 고급 캐시 기능까지 더한 프로젝트예요.",
        tech: ["Rust"],
        repo: "https://github.com/Nergis0318/YU-RI",
    },
    {
        title: "Xync",
        description:
            "깃허브에 핀해 둔 프로젝트예요. 자세한 내용은 곧 공개할게요.",
        tech: [],
        repo: "https://github.com/Nergis0318/Xync",
    },
];
---

<section class="section" id="projects">
    <div class="container">
        <h2 class="section-title reveal">깃허브에 핀한 프로젝트</h2>
        <ul class="grid">
            {
                projects.map((p) => (
                    <li class="card reveal">
                        <div class="card-head">
                            <svg
                                class="folder"
                                width="36"
                                height="36"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="1.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                aria-hidden="true"
                            >
                                <path d="M4 7a2 2 0 0 1 2-2h4l2 2h6a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7z" />
                            </svg>
                            <div class="card-links">
                                <a
                                    href={p.repo}
                                    aria-label={`${p.title} 깃허브에서 보기`}
                                    rel="noopener"
                                >
                                    <svg
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="1.8"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        aria-hidden="true"
                                    >
                                        <path d="M9 19c-4 1.5-4-2-6-2m12 5v-3.5c0-1 .1-1.4-.5-2 2.8-.3 5.5-1.4 5.5-6a4.6 4.6 0 0 0-1.3-3.2 4.2 4.2 0 0 0-.1-3.2s-1.1-.3-3.5 1.3a12.3 12.3 0 0 0-6.2 0C6.5 2.8 5.4 3.1 5.4 3.1a4.2 4.2 0 0 0-.1 3.2A4.6 4.6 0 0 0 4 9.5c0 4.6 2.7 5.7 5.5 6-.6.6-.6 1.2-.5 2V21" />
                                    </svg>
                                </a>
                                {p.link && (
                                    <a
                                        href={p.link}
                                        aria-label={`${p.title} 열기`}
                                        rel="noopener"
                                    >
                                        <svg
                                            width="18"
                                            height="18"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="1.8"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            aria-hidden="true"
                                        >
                                            <path d="M7 17 17 7M9 7h8v8" />
                                        </svg>
                                    </a>
                                )}
                            </div>
                        </div>
                        <h3 class="card-title">
                            {p.link ? (
                                <a href={p.link} rel="noopener" lang="en">
                                    {p.title}
                                </a>
                            ) : (
                                <span lang="en">{p.title}</span>
                            )}
                        </h3>
                        <p class="card-desc">{p.description}</p>
                        <ul class="card-tech">
                            {p.tech.map((t) => (
                                <li lang="en">{t}</li>
                            ))}
                        </ul>
                    </li>
                ))
            }
        </ul>
        <p class="footnote reveal">
            <a
                href="https://github.com/Nergis0318?tab=repositories"
                target="_blank"
                rel="noopener"
            >
                깃허브에서 모든 레포 보기 →
            </a>
        </p>
    </div>
</section>

<style>
    .grid {
        list-style: none;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 18px;
    }
    .card {
        position: relative;
        background: var(--bg-elev);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 26px 24px 22px;
        transition:
            transform var(--transition),
            border-color var(--transition),
            background var(--transition);
    }
    .card:hover {
        transform: translateY(-3px);
        border-color: var(--border-strong);
        background: var(--bg-elev-2);
    }
    .card-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 22px;
    }
    .folder {
        color: var(--text);
    }
    .card-links {
        display: flex;
        gap: 14px;
    }
    .card-links a {
        color: var(--text-muted);
        display: inline-flex;
    }
    .card-links a:hover {
        color: var(--text);
    }
    .card-title {
        font-size: 19px;
        font-weight: 600;
        margin-bottom: 10px;
        color: var(--text);
    }
    .card-title a {
        color: var(--text);
    }
    .card-title a:hover {
        color: var(--text);
        opacity: 0.85;
    }
    .card-desc {
        font-size: 14px;
        color: var(--text-muted);
        line-height: 1.6;
        margin-bottom: 18px;
    }
    .card-tech {
        list-style: none;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
    }
    .card-tech li {
        font-size: 12px;
        color: var(--text-dim);
    }
    .card-tech li:not(:last-child)::after {
        content: "·";
        margin-left: 6px;
    }
    .footnote {
        margin-top: 32px;
        font-size: 13px;
        color: var(--text-muted);
    }
    .footnote a {
        color: var(--text-muted);
        border-bottom: 1px solid var(--border);
        padding-bottom: 2px;
    }
    .footnote a:hover {
        color: var(--text);
        border-color: var(--text);
    }
</style>
